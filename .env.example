# HOSxP Database
HOSXP_HOST=127.0.0.1
HOSXP_USER=readonly_user
HOSXP_PASS=change_me
HOSXP_DB=hos
HOSXP_PORT=3306
HOSXP_READONLY_USER=readonly_user
HOSXP_READONLY_PASS=change_me

# HOSxP Sync Database (required for Excel/API/portal sync)
# Use a dedicated least-privilege account; do not reuse the read-only account.
HOSXP_WRITE_HOST=127.0.0.1
HOSXP_WRITE_PORT=3306
HOSXP_WRITE_DB=hos
HOSXP_WRITE_USER=nae_sync
HOSXP_WRITE_PASS=change_me_to_a_long_random_password

# Internal Tracking Database
TRACKER_HOST=127.0.0.1
TRACKER_USER=tracker_user
TRACKER_PASS=change_me
TRACKER_DB=hos
TRACKER_PORT=3306
TRACKER_CHARSET=utf8mb4

# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=12h
LOGIN_MAX_ATTEMPTS=8
HOSXP_DEV_LOGIN_PASSWORD=

# Encrypts notification tokens stored in the users table; must be at least 32 characters.
NOTIFICATION_CREDENTIALS_KEY=change_me_to_a_different_long_random_secret

# Server
PORT=3005
NODE_ENV=development
DISABLE_NOTIFICATIONS=true
ENABLE_SERVER_BACKGROUND_JOBS=false
# Keep false to disable Live Dashboard, Grafana SQL Table Panel, Embedded Grafana,
# and browser-based dashboard capture. Set true only when capacity is available.
ENABLE_DASHBOARD_MODULES=false
ALLOW_MUTATING_CUSTOM_QUERY=false
# Production browser origin allowlist, comma-separated. Leave blank for same-origin only.
CORS_ORIGINS=
MAX_EXCEL_UPLOAD_BYTES=20971520
ALLOW_PUBLIC_SCREENSHOTS=false
SCHEDULER_LOCK_TTL_SECONDS=1800

# NHSO API
NHSO_API_URL=https://test.nhso.go.th/authencodestatus/api/check-authen-status
NHSO_BEARER_TOKEN=change_me
NHSO_SERVICE_CODE=PG0060001

# NHSO Portal Automation
NHSO_PORTAL_URL=https://authenservice.nhso.go.th/authencode/

# Dashboard Screenshot (Puppeteer)
# Defaults to http://localhost:5174 in development and the local API server in production.
LOCAL_DASHBOARD_URL=http://localhost:5174

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=change_me
LINE_GROUP_ID=change_me
IMGBB_API_KEY=
SERVER_PUBLIC_URL=http://localhost:3005

# Telegram Bot
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_CHAT_ID=change_me
WORKER_TELEGRAM_BOT_TOKEN=
